{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base"
    ],
    "kubernetes": {
        "fileMatch": [
            "(^|/)overlays/.+\\.yaml$",
            "(^|/)base/.+\\.yaml$"
        ]
    },
    "packageRules": [
        {
            "matchDatasources": [
                "docker"
            ],
            "automerge": false,
            "labels": [
                "renovate",
                "dependencies"
            ]
        }
    ]
}